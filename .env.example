PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Image storage
# Local dev: leave empty (defaults to back/Backend/uploads/)
# Railway:   set to the persistent volume mount path (e.g. /app/uploads)
UPLOAD_PATH=

# Public URL used to build image URLs stored in DB
# Local dev: http://localhost:3000
# Railway:   https://your-service.up.railway.app
BASE_URL=http://localhost:3000
